{
  "info": {
    "_postman_id": "bc4264a5-4690-4f4a-bc76-6d5950f5d6ad",
    "name": "Expand Testing Notes API - Newman Stress Demo",
    "description": "Minimal collection for safe Newman stress-test portfolio demo against the health-check endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check Stress",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is below threshold', function () {",
              "  const threshold = Number(pm.environment.get('maxResponseTimeMs') || 2000);",
              "  pm.expect(pm.response.responseTime).to.be.below(threshold);",
              "});",
              "",
              "pm.test('Response has a body', function () {",
              "  pm.expect(pm.response.text()).to.not.equal('');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health-check",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health-check"
          ]
        },
        "description": "Safe endpoint for repeated execution using Newman."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://practice.expandtesting.com/notes/api"
    }
  ]
}
